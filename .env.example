# ==================================================
# SERVER ENVIRONMENT VARIABLES
# ==================================================

# Groq API Key (for Llama 3.3 LLM)
# Get yours free at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Tavily Search API Key (for real-time web research)
# Get your free key at: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ==================================================
# SERVER CONFIG
# ==================================================

# Port the Express server will run on
PORT=5000

# Environment: development | production
NODE_ENV=development

# ==================================================
# CORS CONFIG
# ==================================================

# URL of the frontend client (for CORS whitelist)
CLIENT_URL=http://localhost:5173

# ==================================================
# RATE LIMITING
# ==================================================

# Max requests per IP per window (default: 10 per 15 minutes)
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=900000

# ==================================================
# LLM CONFIG
# ==================================================

# Groq model to use
GROQ_MODEL=llama-3.3-70b-versatile

# LLM temperature (0.0 = deterministic, 1.0 = creative)
# For financial analysis, keep this low
LLM_TEMPERATURE=0.2
